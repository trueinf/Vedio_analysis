# Backend origin only (no /api or /api/jobs suffix). Production example:
# NEXT_PUBLIC_API_BASE=https://your-service.up.railway.app
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_BUCKET=videos

# Files larger than this (bytes) use direct API upload instead of Supabase signed URL (avoids Free-tier ~50MB caps).
# Default: 50331648 (48 MiB). Set higher if your project bucket limit is raised.
# NEXT_PUBLIC_SUPABASE_SIGNED_UPLOAD_MAX_BYTES=50331648

