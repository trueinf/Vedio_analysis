REDIS_URL=redis://localhost:6379/0
# Single-container deploy (Railway + uvicorn only): keep false so jobs run in a daemon thread.
# Set true ONLY if you run a separate process: python -m app.worker (same REDIS_URL + codebase).
USE_RQ_QUEUE=false
# SQLAlchemy database URL (Railway: set DB_URL to your Postgres URL; DATABASE_URL also accepted)
# DB_URL=postgresql://user:pass@host:5432/dbname
# Comma-separated list of allowed frontend origins for CORS
# Include both spellings if you ever used the typo in Netlify project names.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,https://videoanalysis.netlify.app,https://vedioanalysis.netlify.app
# Optional regex for preview deploy URLs
CORS_ORIGIN_REGEX=^https://.*\.netlify\.app$
# Optional: enables diarization if you install pyannote and set a token
# HF_TOKEN=hf_...

# YouTube Data API v3 (required for real channel ingest)
# YOUTUBE_API_KEY=AIza...
# YOUTUBE_MAX_VIDEOS=10

# Supabase (optional persistence: DB + Storage)
# Steps:
# - Run `backend/supabase_sql/schema.sql` in Supabase SQL editor
# - Create a Storage bucket named "videos" (or set SUPABASE_BUCKET)
# - Keep SERVICE_ROLE key server-side only (backend/worker)
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...
# New (Phase 1 dual-write): service key used by `app/supabase_client.py`
# SUPABASE_SERVICE_KEY=...
# SUPABASE_BUCKET=videos
# Optional: max Storage object size in bytes (default 5 GiB). ensure-bucket applies this to the bucket.
# SUPABASE_BUCKET_FILE_SIZE_LIMIT_BYTES=5368709120
#
# If the worker runs on a separate Railway service from the API, the worker must have the
# same Supabase env vars so it can download uploads from Storage (local data/uploads/ is not shared).

# OpenAI (channel AI summaries on POST /api/channels/{name}/summary — server-side only)
# OPENAI_API_KEY=sk-...
# Optional: same vars as FeedbackAgent (app/agents/feedback_agent.py)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# Or only for summaries: OPENAI_CHANNEL_SUMMARY_MODEL=gpt-4o-mini

